#!/usr/bin/env bash
# lair - launch hardened Cyfrin web3 dev containers.
#
# A thin wrapper over the official `devcontainer` CLI: it scaffolds a stack's
# .devcontainer into a project, applies opt-in credential/network flags, then
# opens it in your editor (or a headless shell). The hardened defaults (zero
# credentials, no sudo, default-deny egress) come from the templates; this tool
# only adds what you explicitly ask for. See claude/SECURITY.md for the model.
set -euo pipefail

# --- locate the repo (where the stack templates live), following symlinks ----
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$dir/$SOURCE"
done
REPO_ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"

log() { printf '\033[0;34m[lair]\033[0m %s\n' "$1"; }
warn() { printf '\033[1;33m[lair]\033[0m %s\n' "$1" >&2; }
err() { printf '\033[0;31m[lair]\033[0m %s\n' "$1" >&2; }
die() {
  err "$1"
  exit 1
}

require_devcontainer() {
  command -v devcontainer >/dev/null 2>&1 ||
    die "devcontainer CLI not found. Install: npm i -g @devcontainers/cli"
}
require_jq() { command -v jq >/dev/null 2>&1 || die "jq not found."; }

is_mode() { [[ "$1" == "mounted" || "$1" == "unmounted" ]]; }
# A stack is "lair-ready" only once it has the shared-Dockerfile layout
# (one <stack>/Dockerfile + mounted/ + unmounted/). Today that is `claude`;
# other stacks become available here as they get the same treatment.
is_stack() {
  [[ -f "$REPO_ROOT/$1/Dockerfile" && -d "$REPO_ROOT/$1/mounted" && -d "$REPO_ROOT/$1/unmounted" ]]
}

list_stacks() {
  local d s
  for d in "$REPO_ROOT"/*/; do
    s="$(basename "$d")"
    is_stack "$s" && echo "$s"
  done
}

# Strip // line comments so jq can read a devcontainer.json (JSONC).
strip_jsonc() { sed '/^[[:space:]]*\/\//d' "$1"; }

# Refuse dangerous runArgs that defeat the hardening: SYS_ADMIN lets code remount
# the RO mounts and flush the firewall; --privileged and seccomp/apparmor=unconfined
# are equivalent. Fails CLOSED - an unparseable config is refused, not waved through.
guard_no_sys_admin() {
  local json="$1" args
  if ! args="$(strip_jsonc "$json" | jq -r '(.runArgs // []) | join(" ") | ascii_downcase' 2>/dev/null)"; then
    die "could not parse $json runArgs - refusing (fail closed)."
  fi
  if printf '%s' "$args" | grep -Eq 'sys_admin|privileged|unconfined'; then
    die "dangerous runArgs (SYS_ADMIN / privileged / unconfined) - refusing; defeats the hardening."
  fi
}

print_usage() {
  cat <<EOF
lair - launch hardened web3 dev containers

Usage:
  lair [mounted|unmounted] <stack> [name] [flags]   create + open a container
  lair allow <host> [host...]                       widen the firewall (this project)
  lair up|shell|rebuild|down                         lifecycle (current project)
  lair self-install                                  symlink lair into ~/.local/bin
  lair help                                          this message

Modes:
  unmounted   ephemeral tmpfs workspace (default; strongest isolation)
  mounted     bind-mount the project folder (work persists; requires a name)

Stacks: $(list_stacks | paste -sd ' ' -)

Credential / network opt-ins (off by default):
  --auth            forward host Claude token (else run 'claude login' inside)
  --git-identity    mount ~/.gitconfig read-only
  --gh              add GitHub CLI + its auth volume
  --rpc <url>       allowlist an RPC host (e.g. Alchemy); keep the key in .env
  --allow <host>    allowlist an extra host in the firewall
  --mount <s:d>     bind-mount host path s to container path d
  --ssh / --sudo    NOT YET (Phase 3.1) - see claude/SECURITY.md for manual steps

Examples:
  lair claude                         # unmounted claude, throwaway dir
  lair mounted claude my-audit        # ./my-audit, hardened + persistent
  lair mounted claude p --gh --rpc https://eth-mainnet.g.alchemy.com/v2/KEY
EOF
}

# --- scaffold ----------------------------------------------------------------
scaffold() {
  local mode="$1" stack="$2" target="$3"
  local src="$REPO_ROOT/$stack" dc="$target/.devcontainer"
  mkdir -p "$dc"
  cp "$src/Dockerfile" "$dc/Dockerfile"
  local f
  for f in .zshrc post_install.py init-firewall.sh; do
    [[ -f "$src/$f" ]] && cp "$src/$f" "$dc/$f"
  done
  # Generated config is self-contained: build from the local Dockerfile, and
  # drop the JSONC comments so the result is plain JSON the tooling can edit.
  strip_jsonc "$src/$mode/.devcontainer/devcontainer.json" |
    jq '.build.dockerfile = "Dockerfile" | .build.context = "."' \
      >"$dc/devcontainer.json"
}

jq_edit() { # jq_edit <file> <filter> [jq-args...]
  local file="$1" filter="$2"
  shift 2
  local tmp
  tmp="$(mktemp)"
  # Strip JSONC comments first so this is safe on hand-copied template configs.
  strip_jsonc "$file" | jq "$@" "$filter" >"$tmp"
  mv "$tmp" "$file"
}

# Apply opt-in flags to the generated config. Echoes the credentials added.
# shellcheck disable=SC2016  # jq filters: ${...} are devcontainer vars, not shell
apply_flags() {
  local dc="$1"
  shift
  local json="$dc/devcontainer.json"
  local enabled=() allow_hosts=() host
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --auth)
      jq_edit "$json" '.remoteEnv = ((.remoteEnv // {}) + {"CLAUDE_CODE_OAUTH_TOKEN":"${localEnv:CLAUDE_CODE_OAUTH_TOKEN:}","ANTHROPIC_API_KEY":"${localEnv:ANTHROPIC_API_KEY:}"})'
      enabled+=(auth)
      shift
      ;;
    --git-identity)
      jq_edit "$json" '.mounts = ((.mounts // []) + ["source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly"])'
      enabled+=(git-identity)
      shift
      ;;
    --gh)
      jq_edit "$json" '.features = ((.features // {}) + {"ghcr.io/devcontainers/features/github-cli:1": {}}) | .mounts = ((.mounts // []) + ["source=lair-${localWorkspaceFolderBasename}-gh-${devcontainerId},target=/home/vscode/.config/gh,type=volume"])'
      enabled+=(gh)
      shift
      ;;
    --mount)
      [[ $# -ge 2 ]] || die "--mount needs <host>:<container>"
      local msrc="${2%%:*}" mdst="${2#*:}"
      [[ "$2" == *:* && -n "$msrc" && -n "$mdst" && "$mdst" != *:* ]] ||
        die "--mount needs <host>:<container> (single ':', absolute container path)"
      jq_edit "$json" '.mounts = ((.mounts // []) + [$m])' \
        --arg m "source=$msrc,target=$mdst,type=bind"
      enabled+=("mount($msrc->$mdst)")
      shift 2
      ;;
    --rpc)
      [[ $# -ge 2 ]] || die "--rpc needs <url>"
      host="$(printf '%s' "$2" | sed -E 's#^[a-zA-Z][a-zA-Z0-9+.-]*://##; s#^[^/@]*@##; s#/.*$##; s#:[0-9]+$##')"
      [[ -n "$host" ]] || die "--rpc: could not parse a host from the URL"
      allow_hosts+=("$host")
      shift 2
      ;;
    --allow)
      [[ $# -ge 2 ]] || die "--allow needs <host>"
      [[ "$2" == *[[:space:]]* ]] && die "--allow: one host per flag, no whitespace"
      allow_hosts+=("$2")
      shift 2
      ;;
    --ssh | --sudo)
      warn "$1 is not implemented yet (Phase 3.1); see claude/SECURITY.md for the manual steps."
      shift
      ;;
    *) die "unknown flag: $1" ;;
    esac
  done

  if [[ ${#allow_hosts[@]} -gt 0 ]]; then
    printf '%s\n' "${allow_hosts[@]}" >"$dc/allowed-domains.txt"
    jq_edit "$json" '.mounts = ((.mounts // []) + ["source=${localWorkspaceFolder}/.devcontainer/allowed-domains.txt,target=/etc/devcontainer/allowed-domains.txt,type=bind,readonly"])'
    enabled+=("allow(${allow_hosts[*]})")
  fi

  if [[ ${#enabled[@]} -gt 0 ]]; then
    log "credentials IN:  ${enabled[*]}"
  else
    log "credentials IN:  none (run 'claude login' inside to authenticate)"
  fi
}

open_target() {
  local target="$1"
  if [[ -n "${LAIR_NO_OPEN:-}" ]]; then
    log "scaffolded at $target (LAIR_NO_OPEN set; not opening)"
    return 0
  fi
  local editor=""
  if command -v cursor >/dev/null 2>&1; then
    editor=cursor
  elif command -v code >/dev/null 2>&1; then
    editor=code
  fi
  if [[ -n "$editor" ]]; then
    log "opening in $editor - run 'Reopen in Container' if it doesn't prompt"
    "$editor" "$target"
  else
    log "no VS Code/Cursor CLI; starting a headless container + shell"
    require_devcontainer
    devcontainer up --workspace-folder "$target"
    devcontainer exec --workspace-folder "$target" zsh
  fi
}

cmd_create() {
  local mode="$1" stack="$2" name="$3"
  shift 3
  require_jq
  is_stack "$stack" || die "unknown stack: $stack (have: $(list_stacks | paste -sd ' ' -))"

  local target
  if [[ -n "$name" ]]; then
    mkdir -p -- "$name"
    target="$(cd -- "$name" && pwd)"
  elif [[ "$mode" == "unmounted" ]]; then
    target="$(mktemp -d "${TMPDIR:-/tmp}/lair-$stack.XXXXXX")"
  else
    die "mounted needs a project name: lair mounted $stack <name>"
  fi

  if [[ -d "$target/.devcontainer" && -z "${LAIR_FORCE:-}" ]]; then
    if [[ -t 0 ]]; then
      local reply
      printf '[lair] %s/.devcontainer exists. Overwrite template files? [y/N] ' "$target"
      read -r reply
      [[ "$reply" =~ ^[Yy]$ ]] || die "aborted"
    else
      die "$target/.devcontainer exists; set LAIR_FORCE=1 to overwrite"
    fi
  fi

  log "scaffolding $mode/$stack -> $target"
  scaffold "$mode" "$stack" "$target"
  apply_flags "$target/.devcontainer" "$@"
  guard_no_sys_admin "$target/.devcontainer/devcontainer.json"
  open_target "$target"
}

# shellcheck disable=SC2016  # jq filter: ${localWorkspaceFolder} is a devcontainer var
cmd_allow() {
  [[ $# -ge 1 ]] || die "usage: lair allow <host> [host...]"
  local dc="$PWD/.devcontainer" h
  [[ -d "$dc" ]] || die "no .devcontainer here; run lair from a project dir"
  for h in "$@"; do
    [[ "$h" == *[[:space:]]* ]] && die "allow: one host per arg, no whitespace"
  done
  printf '%s\n' "$@" >>"$dc/allowed-domains.txt"
  require_jq
  if ! strip_jsonc "$dc/devcontainer.json" |
    jq -e '(.mounts // []) | map(select(test("allowed-domains.txt"))) | length > 0' \
      >/dev/null 2>&1; then
    jq_edit "$dc/devcontainer.json" '.mounts = ((.mounts // []) + ["source=${localWorkspaceFolder}/.devcontainer/allowed-domains.txt,target=/etc/devcontainer/allowed-domains.txt,type=bind,readonly"])'
  fi
  log "added to allowlist: $*"
  log "run 'lair rebuild' (or restart the container) to apply"
}

cmd_lifecycle() {
  local sub="$1"
  require_devcontainer
  local ws="$PWD"
  [[ -d "$ws/.devcontainer" ]] || die "no .devcontainer here; run lair from a project dir"
  case "$sub" in
  up) devcontainer up --workspace-folder "$ws" ;;
  rebuild) devcontainer up --workspace-folder "$ws" --remove-existing-container ;;
  shell) devcontainer exec --workspace-folder "$ws" zsh ;;
  down)
    local id
    id="$(docker ps -q --filter "label=devcontainer.local_folder=$ws" 2>/dev/null || true)"
    if [[ -n "$id" ]]; then
      docker stop "$id" >/dev/null && log "stopped $id"
    else
      warn "no running container for $ws"
    fi
    ;;
  esac
}

cmd_self_install() {
  local bin="$HOME/.local/bin"
  mkdir -p "$bin"
  ln -sf "$SOURCE" "$bin/lair"
  log "installed: $bin/lair -> $SOURCE"
  case ":$PATH:" in
  *":$bin:"*) ;;
  *) warn "$bin is not on PATH; add: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
  esac
}

main() {
  [[ $# -gt 0 ]] || {
    print_usage
    exit 1
  }
  local cmd="$1"
  case "$cmd" in
  help | -h | --help)
    print_usage
    exit 0
    ;;
  self-install)
    cmd_self_install
    exit 0
    ;;
  allow)
    shift
    cmd_allow "$@"
    exit 0
    ;;
  up | down | shell | rebuild)
    shift
    cmd_lifecycle "$cmd" "$@"
    exit 0
    ;;
  esac

  # create form: [mode] <stack> [name] [flags...]
  local mode="unmounted"
  if is_mode "$cmd"; then
    mode="$cmd"
    shift
  fi
  local stack="${1:-}"
  [[ -n "$stack" ]] || die "usage: lair [mounted|unmounted] <stack> [name] [flags]"
  shift
  local name=""
  if [[ $# -gt 0 && "$1" != --* ]]; then
    name="$1"
    shift
  fi
  cmd_create "$mode" "$stack" "$name" "$@"
}

main "$@"
