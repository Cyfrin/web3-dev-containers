{
  // Inspired by The Red Guild — https://blog.theredguild.org/where-do-you-run-your-code/
  // Hardening patterns adapted from Trail of Bits (MIT) and Anthropic's reference devcontainer.
  "name": "Cyfrin Claude (mounted, hardened)",
  "build": {
    "dockerfile": "../../Dockerfile",
    "context": "../..",
    "args": { "TZ": "${localEnv:TZ:UTC}" }
  },
  "runArgs": ["--cap-add=NET_ADMIN", "--cap-add=NET_RAW"],
  "waitFor": "postStartCommand",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "init": true,
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": { "zsh": { "path": "/usr/bin/zsh" } }
      }
    }
  },
  "mounts": [
    "source=devc-${localWorkspaceFolderBasename}-claude-history-${devcontainerId},target=/commandhistory,type=volume",
    "source=devc-${localWorkspaceFolderBasename}-claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer,target=/workspace/.devcontainer,type=bind,readonly",
    "source=${localWorkspaceFolder}/.git/config,target=/workspace/.git/config,type=bind,readonly",
    "source=${localWorkspaceFolder}/.git/hooks,target=/workspace/.git/hooks,type=bind,readonly"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "GIT_CONFIG_GLOBAL": "/home/vscode/.gitconfig.local",
    "SSH_AUTH_SOCK": ""
  },
  "initializeCommand": "bash -c 'git -C \"${localWorkspaceFolder}\" init -q 2>/dev/null || true'",
  "postCreateCommand": "uv run --no-project /opt/post_install.py; echo 'Cyfrin Claude dev container ready (no credentials). Run: claude login — https://www.cyfrin.io/blog/reduce-the-risk-of-cyber-attacks-isolated-dev-environments'"
}
